{
  "expo": {
    "name": "Underwave",
    "slug": "underwave",
    "version": "1.0.0",
    "scheme": "underwave",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.underwave.app"
    },
    "android": {
      "package": "com.underwave.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
